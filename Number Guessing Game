number = random.randint(1, 50)

guess = 0
attempts = 0

print("Guess a number between 1 and 50")

while guess != number:
    guess = int(input("Enter your guess: "))
    attempts = attempts + 1

    if guess < number:
        print("Too low")

    elif guess > number:
        print("Too high")

    else:
        print("You guessed it!")
        print("Attempts:", attempts)

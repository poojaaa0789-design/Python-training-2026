import csv

FILENAME = "library_books.csv"


class Library:

    def add_book(self):
        title = input("Enter book title: ")
        author = input("Enter author name: ")
        year = input("Enter publication year: ")

        try:
            file = open(FILENAME, "a", newline="", encoding="utf-8")
            writer = csv.writer(file)
            writer.writerow([title, author, year])
            file.close()

            print("Book added successfully!")

        except:
            print("Something went wrong.")


    def search_book(self):
        title = input("Enter title to search: ").lower()
        found = False

        try:
            file = open(FILENAME, "r", encoding="utf-8")
            reader = csv.reader(file)

            for row in reader:
                if row:
                    if title in row[0].lower():
                        print("Book Found")
                        print("Title :", row[0])
                        print("Author :", row[1])
                        print("Year :", row[2])
                        found = True

            file.close()

            if found == False:
                print("Book not found.")

        except:
            print("Library file does not exist.")


    def remove_book(self):
        title = input("Enter book title to remove: ").lower()

        books = []
        found = False

        try:
            file = open(FILENAME, "r", encoding="utf-8")
            reader = csv.reader(file)

            for row in reader:
                if row:
                    if row[0].lower() == title:
                        found = True
                    else:
                        books.append(row)

            file.close()

            file = open(FILENAME, "w", newline="", encoding="utf-8")
            writer = csv.writer(file)
            writer.writerows(books)
            file.close()

            if found:
                print("Book removed.")
            else:
                print("Book not found.")

        except:
            print("Error occurred.")


    def display_books(self):

        try:
            file = open(FILENAME, "r", encoding="utf-8")
            reader = csv.reader(file)

            print("\nBooks in Library")

            empty = True

            for row in reader:
                if row:
                    print(row[0], "-", row[1], "-", row[2])
                    empty = False

            file.close()

            if empty:
                print("No books available.")

        except:
            print("Library file not found.")


obj = Library()

while True:

    print("\n1. Add Book")
    print("2. Search Book")
    print("3. Remove Book")
    print("4. Display Books")
    print("5. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        obj.add_book()

    elif choice == "2":
        obj.search_book()

    elif choice == "3":
        obj.remove_book()

    elif choice == "4":
        obj.display_books()

    elif choice == "5":
        print("Program Ended")
        break

    else:
        print("Invalid Choice")

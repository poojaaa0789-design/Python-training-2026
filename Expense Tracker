
import os

FILENAME = "expenses.txt"

def log_expense():
    print("\n--- Log a New Expense ---")
    
  
    try:
        amount = float(input("Enter amount spent: $"))
        if amount <= 0:
            print(" Amount must be greater than zero.")
            return
    except ValueError:
        print(" Invalid input! Please enter a valid number for the amount.")
        return

   
    category = input("Enter category (e.g., Food, Transport, Rent): ").strip().title()
    description = input("Enter a short description: ").strip()

    if not category or not description:
        print(" Category and Description cannot be empty.")
        return


    with open(FILENAME, mode="a", encoding="utf-8") as file:
        file.write(f"{category} | {amount:.2f} | {description}\n")
    
    print(f" Logged: ${amount:.2f} under '{category}'.")


def summarize_expenses():
    print("\n Expense Summary by Category ")
    
    if not os.path.exists(FILENAME):
        print(" No expenses logged yet. Your file is empty!")
        return

    category_totals = {}
    grand_total = 0.0

    try:
        with open(FILENAME, mode="r", encoding="utf-8") as file:
            for line_num, line in enumerate(file, 1):
             
                parts = line.strip().split(" | ")
                
              
                if len(parts) == 3:
                    category, amount_str, description = parts
                    try:
                        amount = float(amount_str)
                        
                        
                        category_totals[category] = category_totals.get(category, 0.0) + amount
                        grand_total += amount
                    except ValueError:
                        print(f" Skipping corrupted data on line {line_num}.")
                        
        if not category_totals:
            print("No valid expense data found.")
            return

       
        print(f"{'Category':<15} | {'Total Spent':<12}")
        print("-" * 30)
        for category, total in category_totals.items():
            print(f"{category:<15} | {total:>10.2f}")
        print("-" * 30)
        print(f"{'GRAND TOTAL':<15} | {grand_total:>10.2f}")

    except Exception as e:
        print(f" An error occurred while reading the file: {e}")


while True:
    
    print("1. Log an Expense")
    print("2. View Category Summary")
    print("3. Exit")
    
    choice = input("Choose an option (1-3): ").strip()
    
    if choice == "1":
        log_expense()
    elif choice == "2":
        summarize_expenses()
    elif choice == "3":
        print("Goodbye! ")
        break
    else:
        print("Invalid choice. Please enter 1, 2, or 3.")
